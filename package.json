{
  "name": "orca-strator",
  "version": "0.1.0",
  "description": "Orchestrate and run multiple AI coding agents in parallel (cross-platform desktop: Windows + macOS + Linux)",
  "main": "./out/main/index.js",
  "author": "Nehmo101",
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "homepage": "https://github.com/Nehmo101/Orca-Strator",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nehmo101/Orca-Strator.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "icons": "node scripts/gen-icons.mjs",
    "build": "pnpm run icons && pnpm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "retro:analyze": "tsx scripts/retro-analyze.ts",
    "test:ui-smoke": "node scripts/ui-smoke.mjs",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac --universal",
    "build:linux": "pnpm run build && electron-builder --linux",
    "ci": "pnpm run icons && pnpm run lint && pnpm run typecheck && pnpm run test && electron-vite build"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@lydell/node-pty": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.9",
    "zustand": "^5.0.0"
  }
}
